/* FCBillar — tema fosc, aplicat al QApplication */

QWidget {
    background-color: #1f2329;
    color: #e4e7ec;
    font-family: "Segoe UI", "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
    font-size: 13px;
}

QMainWindow, QStackedWidget {
    background-color: #1f2329;
}

#sidebar {
    background-color: #161a20;
    border-right: 1px solid #2a2f37;
    color: #c0c6cf;
    padding: 12px 0;
    font-size: 14px;
}
#sidebar::item {
    padding: 12px 16px;
    border-radius: 6px;
    margin: 2px 8px;
}
#sidebar::item:selected {
    background-color: #2d6cdf;
    color: #ffffff;
}
#sidebar::item:hover:!selected {
    background-color: #232932;
}

#sectionTitle {
    font-size: 18px;
    font-weight: 600;
    color: #f0f3f8;
    padding: 4px 0 8px 0;
}

#kpiCard {
    background-color: #272d36;
    border: 1px solid #353c47;
    border-radius: 10px;
}
#kpiCard:hover {
    border-color: #4a5468;
}
#kpiLabel {
    color: #93a0b3;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
#kpiValue {
    color: #ffffff;
    font-size: 24px;
    font-weight: 600;
}

QTableWidget {
    background-color: #272d36;
    alternate-background-color: #232932;
    gridline-color: #353c47;
    border: 1px solid #353c47;
    border-radius: 6px;
    selection-background-color: #2d6cdf;
    selection-color: #ffffff;
}
QHeaderView::section {
    background-color: #1c2128;
    color: #93a0b3;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #353c47;
    font-weight: 600;
}
QTableWidget::item {
    padding: 6px 8px;
}

QTabWidget::pane {
    border: 1px solid #353c47;
    border-radius: 6px;
    background-color: #272d36;
}
QTabBar::tab {
    background-color: #1c2128;
    color: #93a0b3;
    padding: 8px 16px;
    border: 1px solid #353c47;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}
QTabBar::tab:selected {
    background-color: #272d36;
    color: #ffffff;
}
QTabBar::tab:hover:!selected {
    background-color: #232932;
}

QLineEdit {
    background-color: #272d36;
    border: 1px solid #353c47;
    border-radius: 6px;
    padding: 8px 12px;
    color: #f0f3f8;
}
QLineEdit:focus {
    border-color: #2d6cdf;
}

QPushButton {
    background-color: #2d6cdf;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 18px;
    font-weight: 500;
}
QPushButton:hover {
    background-color: #3d7ce8;
}
QPushButton:pressed {
    background-color: #1e58c5;
}

QStatusBar {
    background-color: #161a20;
    color: #93a0b3;
    border-top: 1px solid #2a2f37;
}

QSplitter::handle {
    background-color: #2a2f37;
}
QSplitter::handle:horizontal {
    width: 2px;
}
QSplitter::handle:vertical {
    height: 2px;
}

QScrollBar:vertical {
    background: #1f2329;
    width: 12px;
}
QScrollBar::handle:vertical {
    background: #3d4452;
    border-radius: 6px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background: #4a5468;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QMessageBox {
    background-color: #272d36;
}
QLabel {
    background: transparent;
}
